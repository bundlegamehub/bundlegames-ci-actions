# BundleGames shared .editorconfig baseline.
# Copy into each game repo via scripts/install-shared-config.sh.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Languages that conventionally use 4-space indent
[*.{java,kt,kts}]
indent_size = 4

[*.{py}]
indent_size = 4

[*.{cs}]
indent_size = 4

# Makefiles require tabs
[Makefile]
indent_style = tab

# Go uses tabs
[*.go]
indent_style = tab

# Markdown — don't trim trailing whitespace (used for line breaks)
[*.md]
trim_trailing_whitespace = false
